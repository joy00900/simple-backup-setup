# Database Configuration
DB_HOST=db
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=testdb

# Backup Configuration
ENABLE_BACKUP=true

# Google Drive Configuration
# Get these from: https://console.cloud.google.com/
# Steps:
# 1. Create a Google Cloud project
# 2. Enable Google Drive API
# 3. Create a service account or OAuth 2.0 credentials (OAuth 2.0 Desktop App)
# 4. Save the credentials JSON file as .google-drive-credentials.json
# 5. Run: npm run backup (it will guide you through authentication)
# 6. Get your Google Drive folder ID and set it below

# Path to Google Drive credentials file (typically .google-drive-credentials.json)
GOOGLE_DRIVE_CREDENTIALS_PATH=.google-drive-credentials.json

# Google Drive folder ID where backups will be stored
# Find this by right-clicking the folder in Google Drive and selecting "Get link"
# It's the ID in the URL: https://drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=root

# ============================================
# Alert Configuration (Gmail)
# ============================================
# Enable Gmail notifications for backup success/failure
GMAIL_EMAIL=your-email@gmail.com

# Use Google App Password (NOT your regular password)
# Generate at: https://myaccount.google.com/apppasswords
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Google will generate a 16-character password
# 5. Paste it below (without spaces)
GMAIL_APP_PASSWORD=your-app-password-here

# Where to send alert emails (defaults to GMAIL_EMAIL if not set)
ALERT_EMAIL_TO=your-email@gmail.com

# ============================================
# Alert Configuration (Microsoft Teams)
# ============================================
# Enable Microsoft Teams notifications for backup success/failure
# Get webhook URL from: https://teams.microsoft.com -> Apps -> Webhooks

# Configure Incoming Webhook:
# 1. Open Microsoft Teams
# 2. Go to the channel where you want alerts
# 3. Click ... (More options) → Connectors
# 4. Search for "Incoming Webhook"
# 5. Click Configure
# 6. Give it a name (e.g. "Backup Alerts")
# 7. Copy the webhook URL and paste below

MS_TEAMS_WEBHOOK_URL=https://outlook.webhook.office.com/webhookb2/...

